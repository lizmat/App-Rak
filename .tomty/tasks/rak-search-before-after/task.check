!raku
say "file.txt";
my $j = 1;

for (1..config()<lines-before>) -> $i {
  say "regexp: ", '^^\s+', " '{$j++}:' \\s+ 'line_before{$i}'", ' \s* $$';
}
say "regexp: ", '^^\s*', "'{$j++}:' \\s+ 'foo'", ' \s* $$';

for (1..config()<lines-after>) -> $i {
  say "regexp: ", '^^\s+', " '{$j++}:' \\s+ 'line_after{$i}'", ' \s* $$';
}
CODE
