!raku
say "file.txt";
my $j = 1;

for (1..config()<lines-before>) -> $i {
  say "regexp: ", '^^\s*', " '{$j++}-line_before{$i}'", ' \s* $$';
}
say "regexp: ", '^^\s*', "'{$j++}:foo'", ' \s* $$';

for (1..config()<lines-after>) -> $i {
  say "regexp: ", '^^\s*', " '{$j++}-line_after{$i}'", ' \s* $$';
}
CODE
